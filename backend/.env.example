# NextOwner backend configuration — copy to `.env` (gitignored) and fill in.
# Never commit real secrets. security.md §Secrets / §9.

# Database — SQLite locally; swap to a Postgres URL later (no code change).
DATABASE_URL=sqlite:///nextowner.db

# JWT — MUST be a strong random value (>=32 bytes) in any real environment.
# e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=dev-only-change-me-use-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Login rate limiting (brute-force / credential-stuffing defence).
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Leave false everywhere except tests — mounts the /_debug/boom route.
ENABLE_DEBUG_ROUTES=false
